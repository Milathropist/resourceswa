<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ page.title }} | {{ site.title }}</title>
    <link rel="icon" type="image/png" href="{{ '/images/Favicon.png' | relative_url }}">
    <link rel="stylesheet" href="{{ '/assets/css/main.css' | relative_url }}" />
    <style>
      body {
        min-height: 100vh;
        margin: 0;
        padding: 2.5rem 1.25rem;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        background-image: radial-gradient(circle at 20% 20%, rgba(245, 131, 182, 0.25), transparent 40%), radial-gradient(circle at 80% 0%, rgba(120, 70, 180, 0.35), transparent 35%), url("{{ '/images/bg.jpg' | relative_url }}");
        background-size: cover;
        background-attachment: fixed;
      }

      .page-shell {
        width: min(100%, 850px);
        background: rgba(108, 63, 138, 0.82);
        border-radius: 0.45rem;
        border: 1px solid rgba(255, 255, 255, 0.16);
        box-shadow: 0 0.75rem 2rem rgba(24, 12, 35, 0.4);
        backdrop-filter: blur(3px);
      }

      .page-inner {
        padding: 2.4rem;
      }

      .close-link {
        position: fixed;
        top: 1rem;
        right: 1rem;
        z-index: 1000;
        width: 2.25rem;
        height: 2.25rem;
        line-height: 2.25rem;
        border-radius: 999px;
        text-align: center;
        text-decoration: none;
        border-bottom: 0;
        background: rgba(81, 43, 127, 0.8);
        color: rgba(255, 255, 255, 0.85);
      }

      .hero {
        margin: 0 0 1.8rem;
      }

      .hero img {
        width: 100%;
        border-radius: 0.25rem;
        display: block;
      }

      .hero h1 {
        margin-top: 1rem;
        text-align: center;
        letter-spacing: 0.14rem;
      }

      nav ul {
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
        justify-content: center;
        list-style: none;
        padding: 0;
        margin: 0 0 1.2rem;
      }

      nav a {
        border-bottom: none;
        padding: 0.2rem 0.7rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
      }

      .toc {
        background: rgba(238, 162, 214, 0.23);
        padding: 0.95rem;
        border-radius: 0.3rem;
      }

      .article-block {
        margin-top: 1.25rem;
        padding: 1rem;
        border-radius: 0.25rem;
        background: rgba(231, 161, 217, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .article-block h2 {
        margin-bottom: 0.55rem;
      }

      .article-cover {
        margin: 0 0 1rem;
      }

      .article-cover img {
        width: 100%;
        display: block;
        border-radius: 0.2rem;
      }

      .article-link {
        font-size: 0.9rem;
        opacity: 0.85;
      }
  
      .collapsible {
        border-radius: 25px;
        background-color: rgba(158, 157, 157, 0.027);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-top: 1px solid rgba(158, 157, 157, 0.4);
        border-left: 1px solid rgba(158, 157, 157, 0.3);
        box-shadow: 3px 3px 3px rgba(0, 0, 0, 0.085);
        color: white;
        cursor: pointer;
        padding: 1px 22px;
        width: 100%;
        text-align: left;
        outline: none;
        font-size: 15px;
      }

      .active,
      .collapsible:hover {
        border-radius: 25px;
        background-color: rgba(76, 75, 75, 0.027);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-top: 1px solid rgba(76, 75, 75, 0.4);
        border-left: 1px solid rgba(176, 75, 75, 0.3);
        box-shadow: 3px 3px 3px rgba(0, 0, 0, 0.085);
      }

      .collapsible:after {
        content: "\002B";
        color: white;
        font-weight: bold;
        float: right;
        margin-left: 2px;
        flex-shrink: 0;
        transition: transform 0.25s ease, opacity 0.2s ease;
      }

      .active:after {
        content: "\2212";
        transform: rotate(180deg);
      }

      .collapse-content {
        display: none;
        padding: 0 36px;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.2s ease-out;
        margin-top: 0.5rem;
        background-color: rgba(0, 0, 0, 0);
      }

      .collapse-content.open {
        display: block;
      }

      @media (max-width: 640px) {
        .page-inner {
          padding: 1.4rem;
        }
      }
    </style>
  </head>
  <body>
    <main class="page-shell">
      <div class="page-inner">
        <div class="page-top">
          <a class="close-link" href="{{ '/' | relative_url }}" aria-label="Back to home">×</a>
          {% include nav.html %}
          <header class="hero">
            {% if page.hero_image %}
              <img src="{{ page.hero_image | relative_url }}" alt="{{ page.title }}" />
            {% endif %}
            <h1>{{ page.title }}</h1>
          </header>
        </div>
        {{ content }}
      </div>
    </main>
    <script>
      const spoilerNodes = document.querySelectorAll("spo");
      spoilerNodes.forEach((node) => {
        node.setAttribute("tabindex", "0");
        node.setAttribute("role", "button");
        node.addEventListener("click", () => node.classList.toggle("revealed"));
        node.addEventListener("keydown", (event) => {
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            node.classList.toggle("revealed");
          }
        });
      });
      
      const collapsibleNodes = document.querySelectorAll(".collapsible");
      collapsibleNodes.forEach((node) => {
        node.addEventListener("click", () => {
          node.classList.toggle("active");
          const content = node.nextElementSibling;
          if (!content) return;

          content.classList.toggle("open");
        });
      });
    </script>
  </body>
</html>
